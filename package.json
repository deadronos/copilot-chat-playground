{
  "name": "copilot-chat-playground",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "ci:coverage": "pnpm -F @copilot-playground/backend test:coverage && pnpm -F @copilot-playground/frontend test:coverage && pnpm -F @copilot-playground/copilot test:coverage",
    "ci:guardrails": "node scripts/ci/check-router-thin.mjs",
    "dev:frontend": "pnpm --filter @copilot-playground/frontend dev",
    "dev:backend": "pnpm --filter @copilot-playground/backend dev",
    "dev:copilot": "pnpm --filter @copilot-playground/copilot dev"
  }
}
